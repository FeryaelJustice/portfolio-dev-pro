---
import "@fontsource-variable/onest";
import "@fontsource-variable/space-grotesk";
import "../styles/global.css";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import { ui } from "@i18n/ui";
import type { Lang } from "@i18n/utils";

interface Props {
    lang: Lang;
}

const { lang } = Astro.props;
const t = (k: keyof (typeof ui)["en"]) => ui[lang][k];
const title = t("meta.title");
const description = t("meta.description");
const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang={lang} class="dark">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />
        <meta name="theme-color" content="#0c1311" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" type="image/x-icon" href="/favicon.ico" />
        <link rel="canonical" href={canonical} />

        <title>{title}</title>
        <meta name="description" content={description} />
        <meta name="author" content="Fernando González Serrano" />

        <!-- Open Graph -->
        <meta property="og:type" content="website" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={canonical} />
        <meta property="og:locale" content={lang === "es" ? "es_ES" : "en_US"} />
        <meta name="twitter:card" content="summary_large_image" />

        <link rel="alternate" hreflang="en" href={new URL("/", Astro.site)} />
        <link rel="alternate" hreflang="es" href={new URL("/es/", Astro.site)} />
    </head>
    <body class="min-h-screen">
        <a
            href="#main"
            class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-m3-lg focus:bg-primary focus:px-4 focus:py-2 focus:text-on-primary"
        >
            {lang === "es" ? "Saltar al contenido" : "Skip to content"}
        </a>
        <Header lang={lang} />
        <main id="main">
            <slot />
        </main>
        <Footer lang={lang} />
    </body>
</html>
