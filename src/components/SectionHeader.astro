---
interface Props {
    eyebrow: string;
    title: string;
    subtitle?: string;
    align?: "left" | "center";
}
const { eyebrow, title, subtitle, align = "left" } = Astro.props;
---

<div class:list={["max-w-2xl", align === "center" && "mx-auto text-center"]}>
    <span
        class="inline-flex items-center gap-2 rounded-m3-xl border border-outline-variant bg-surface-2/60 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-primary"
    >
        <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
        {eyebrow}
    </span>
    <h2
        class="mt-4 text-balance text-3xl font-bold tracking-tight text-on-surface sm:text-4xl lg:text-5xl"
    >
        {title}
    </h2>
    {
        subtitle && (
            <p class="mt-4 text-pretty text-base text-on-surface-variant sm:text-lg">
                {subtitle}
            </p>
        )
    }
</div>
